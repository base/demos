{{#if (eq wallet "cdp-server-wallet")}}
# CDP Server Wallet
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# Optional: set to reuse an existing CDP account (defaults to "{{name}}-primary" which creates a new wallet)
# CDP_EVM_ACCOUNT_NAME=my-existing-account
{{/if}}
{{#if isBankr}}
# Bankr Agent API
BANKR_API_KEY=bk_...
{{/if}}
{{#if isSponge}}
# Sponge Wallet
SPONGE_API_KEY=
{{/if}}

# Base Mainnet
RPC_URL={{rpcUrl}}
CHAIN_ID={{chainId}}

# LLM
LLM_PROVIDER={{llm}}
LLM_MODEL={{model}}
{{#if isVenice}}
VENICE_API_KEY={{llmApiKey}}
VENICE_BASE_URL=https://api.venice.ai/api/v1
{{else}}
LLM_API_KEY={{llmApiKey}}
{{/if}}

{{#if hasUniswap}}
# Uniswap Trading API (get key at https://hub.uniswap.org)
UNISWAP_API_KEY=

{{/if}}
{{#if hasNansenMcp}}
# Nansen MCP (blockchain analytics via MCP server)
NANSEN_API_KEY=

{{/if}}
{{#if hasAgentcashMcp}}
# AgentCash MCP (optional bootstrap invite code)
AGENTCASH_INVITE_CODE=
# Optional: override AgentCash wallet private key or enable debug logs
# X402_PRIVATE_KEY=
# X402_DEBUG=true

{{/if}}
{{#if hasNansenX402}}
# Nansen x402 (override default endpoint if needed)
# NANSEN_X402_URL=https://api.nansen.ai/x402

{{/if}}
{{#if hasVirtuals}}
# Virtuals ACP CLI
# Install the ACP CLI so the `acp` command is available, or point this at the executable path.
VIRTUALS_ACP_BIN=acp

{{/if}}
# Agent Loop
TEST_MODE={{testMode}}
AGENT_INTERVAL_SECONDS={{defaultAgentIntervalSeconds}}
{{#if isSelfUpdating}}

# Self-Updating Strategy
SELF_UPDATING=true
EVALUATION_INTERVAL_MINUTES={{evaluationInterval}}
{{/if}}

# Guardrails
SLIPPAGE_PCT={{defaultSlippagePct}}
STOP_LOSS_PCT={{defaultStopLossPct}}
MAX_POSITION_PCT={{defaultMaxPositionPct}}

# LangSmith (optional tracing — uncomment to enable)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT={{name}}
