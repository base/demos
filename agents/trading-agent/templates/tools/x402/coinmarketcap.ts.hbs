import { DynamicStructuredTool } from "@langchain/core/tools";
import { z } from "zod";
import { getX402Fetch } from "./client.js";
import { okResult, errorResult, normalizeError } from "../../tool-result.js";

const CMC_X402_URL = "https://pro-api.coinmarketcap.com/x402";

function formatApiError(status: number, statusText: string): string {
  if (status === 402) {
    return `CoinMarketCap x402 payment failed: ${status} ${statusText}. Check wallet funding and x402 signer setup.`;
  }
  return `CoinMarketCap API error: ${status} ${statusText}`;
}

export function getCoinMarketCapTools() {
  return [
    new DynamicStructuredTool({
      name: "coinmarketcap_get_quote",
      description:
        "Get current price quote and market data from CoinMarketCap (x402 pay-per-request).",
      schema: z.object({
        id: z
          .string()
          .describe("CoinMarketCap cryptocurrency ID(s), e.g. '1' for BTC, '1027' for ETH. Comma-separated for multiple."),
      }),
      func: async ({ id }) => {
        try {
          const fetchWithPayment = getX402Fetch();
          const url = `${CMC_X402_URL}/v3/cryptocurrency/quotes/latest?id=${id}`;
          const res = await fetchWithPayment(url, { signal: AbortSignal.timeout(10000) });
          if (!res.ok) {
            return errorResult(formatApiError(res.status, res.statusText));
          }
          const data = await res.json();
          return okResult({ data });
        } catch (e) {
          return errorResult(normalizeError(e));
        }
      },
    }),
    new DynamicStructuredTool({
      name: "coinmarketcap_listing_latest",
      description:
        "Get a paginated list of active cryptocurrencies ranked by market cap from CoinMarketCap (x402 pay-per-request).",
      schema: z.object({
        start: z.number().describe("Rank offset to start from (default 1)"),
        limit: z.number().describe("Number of results (max 100, default 10)"),
      }),
      func: async ({ start, limit }) => {
        try {
          const fetchWithPayment = getX402Fetch();
          const url = `${CMC_X402_URL}/v3/cryptocurrency/listing/latest?start=${start}&limit=${limit}`;
          const res = await fetchWithPayment(url, { signal: AbortSignal.timeout(10000) });
          if (!res.ok) {
            return errorResult(formatApiError(res.status, res.statusText));
          }
          const data = await res.json();
          return okResult({ data });
        } catch (e) {
          return errorResult(normalizeError(e));
        }
      },
    }),
    new DynamicStructuredTool({
      name: "coinmarketcap_dex_search",
      description:
        "Search for DEX tokens by keyword (name, symbol, or contract address) via CoinMarketCap (x402 pay-per-request).",
      schema: z.object({
        q: z.string().describe("Search query — token name, symbol, or contract address"),
      }),
      func: async ({ q }) => {
        try {
          const fetchWithPayment = getX402Fetch();
          const url = `${CMC_X402_URL}/v1/dex/search?q=${encodeURIComponent(q)}`;
          const res = await fetchWithPayment(url, { signal: AbortSignal.timeout(10000) });
          if (!res.ok) {
            return errorResult(formatApiError(res.status, res.statusText));
          }
          const data = await res.json();
          return okResult({ data });
        } catch (e) {
          return errorResult(normalizeError(e));
        }
      },
    }),
  ];
}
